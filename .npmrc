# ── Shared npm + pnpm settings ───────────────────────────────────────────────
# Run scripts normally (default for npm; explicit for older pnpm versions).
ignore-scripts=false

# ── pnpm-only settings (npm ignores these keys silently in older versions,
#    but newer npm versions warn on unknown keys — that's harmless) ───────────
node-linker=hoisted
allow-scripts=all
only-built-dependencies=esbuild
